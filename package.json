{
  "name": "chatgpt-playwright-dataset-builder",
  "version": "1.0.0",
  "description": "Playwright automation: sends prompts to ChatGPT, intercepts network responses, extracts result_source + citations → CSV dataset",
  "main": "scraper.js",
  "scripts": {
    "login": "node login.js 1",
    "login:1": "node login.js 1",
    "login:2": "node login.js 2",
    "login:3": "node login.js 3",
    "login:4": "node login.js 4",
    "login:5": "node login.js 5",
    "manual-auth": "node manual_auth.js",
    "extract-cookies": "node extract_cookies.js",
    "start": "node scraper.js",
    "test": "node scraper.js --dry-run",
    "parallel": "node scraper-parallel.js",
    "parallel:1": "node scraper-parallel.js --workers=1",
    "parallel:test": "node scraper-parallel.js --dry-run",
    "parallel:3": "node scraper-parallel.js --workers=3",
    "parallel:force-search": "node scraper-parallel.js --force-search",
    "parallel:force-search:test": "node scraper-parallel.js --dry-run --force-search"
  },
  "keywords": [
    "playwright",
    "chatgpt",
    "automation",
    "dataset"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "csv-parse": "^5.5.3",
    "csv-stringify": "^6.4.5",
    "fs-extra": "^11.2.0",
    "playwright": "^1.40.0"
  }
}
